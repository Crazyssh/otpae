# Caddy listen di port 8080 (HTTP only).
# SSL/HTTPS di-handle Cloudflare di depan.
# Ganti "api.happypixel.net" sama domain bang.

{
	# Matiin auto-HTTPS karena pake Cloudflare buat SSL
	auto_https off
	http_port 8080
}

http://api.happypixel.net:8080, http://:8080 {
	reverse_proxy localhost:3999 {
		# SSE support: jangan buffer
		flush_interval -1
		transport http {
			read_timeout 1h
			write_timeout 1h
		}
	}

	encode gzip

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer-when-downgrade"
	}

	log {
		output file logs/access.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}
