# ==== JasaOTP Settings ====
JASAOTP_API_KEY=isi_api_key_jasaotp_disini
JASAOTP_BASE_URL=https://api.jasaotp.id/v1

# ==== Server ====
PORT=3000

# ==== Admin Login ====
