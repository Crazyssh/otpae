# ==== Upstream Settings ====
# API key dari penyedia OTP (bisa juga di-set lewat dashboard admin)
JASAOTP_API_KEY=
# Base URL upstream
JASAOTP_BASE_URL=https://api.ditznesia.com/v1

# ==== Server ====
PORT=3999

# ==== Admin Login ====
# Password untuk masuk dashboard admin di /admin
ADMIN_PASSWORD=ganti_dengan_password_kuat

# ==== Background Poller ====
POLL_INTERVAL_MS=5000
# Default 30 menit. Atur lebih lama dari timeout JasaOTP biar kita gak duluan nyerah.
POLL_TIMEOUT_MS=1800000

# ==== Sync ====
# Berapa negara di-sync paralel (default 8)
SYNC_CONCURRENCY=8
